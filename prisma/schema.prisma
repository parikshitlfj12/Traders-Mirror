// Trader's Mirror — Prisma schema
// Source of truth: PRD §5. Do not invent new tables without approval.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// USERS — simple email/password auth
// =============================================================================
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  displayName   String?
  timezone      String   @default("UTC")
  primaryMarket Market   @default(CRYPTO)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trades     Trade[]
  voiceNotes VoiceNote[]
  projects   Project[]
}

enum Market {
  FOREX
  CRYPTO
  BOTH
}

// =============================================================================
// PROJECTS — campaign container (replaces the old Contract concept).
// Holds financial parameters + behavioral rules together.
// =============================================================================
model Project {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name     String
  startsAt DateTime
  // Optional: open-ended campaigns (e.g. ongoing personal challenges) leave
  // this null. Range-based queries fall back to "never expires" when null.
  endsAt   DateTime?
  isActive Boolean   @default(true)

  // Financial parameters — the "plan"
  startingCapital Decimal @db.Decimal(18, 2)
  maxDrawdown     Decimal @db.Decimal(18, 2) // absolute amount in account currency
  dailyDrawdown   Decimal @db.Decimal(18, 2) // absolute amount in account currency
  profitTarget    Decimal @db.Decimal(18, 2) // absolute amount in account currency

  // Behavioral rules — natural-language source + structured children
  rawText   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rules      Rule[]
  violations RuleViolation[]
  trades     Trade[]
  voiceNotes VoiceNote[]

  @@index([userId, isActive])
}

model Rule {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  category    RuleCategory
  description String
  params      Json // { max: 3, period: "day" } — machine-checkable
  severity    Severity     @default(MEDIUM)
  version     Int          @default(1) // bumped when edited mid-project
  isActive    Boolean      @default(true) // false = superseded by newer version
  createdAt   DateTime     @default(now())

  violations RuleViolation[]

  @@index([projectId, isActive])
}

enum RuleCategory {
  MAX_TRADES_PER_DAY
  MAX_TRADES_PER_WEEK
  MAX_DAILY_LOSS
  MAX_WEEKLY_LOSS
  MAX_RISK_PER_TRADE
  POSITION_SIZE_CAP
  NO_REVENGE_TRADING
  NO_SIZE_INCREASE_AFTER_LOSS
  APPROVED_SETUPS_ONLY
  ALLOWED_SESSIONS_ONLY
  NO_FOMO_ENTRIES
  REQUIRES_CONFIRMATION
  CUSTOM
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model RuleViolation {
  id        String  @id @default(uuid())
  ruleId    String
  rule      Rule    @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  voiceNoteId String?
  tradeId     String?

  detectedBy String // "ai" | "system" | "manual"
  evidence   String   @db.Text
  detectedAt DateTime @default(now())

  @@index([projectId, detectedAt])
}

// =============================================================================
// TRADES — the atomic unit. Auto-created when a recording is analysed.
// All market fields are nullable: a fresh trade in TODO has nothing filled in;
// AI extraction (or the user) fills them in over time. See PRD §1.4 + §5.
// =============================================================================
model Trade {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?  // null = freehand trade
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Market fields — all nullable. Populated by AI extraction (when confidence
  // >= MERGE_CONFIDENCE_THRESHOLD and the slot is still null) or by the user.
  symbol     String?
  market     Market?
  direction  Direction?
  size       Decimal?   @db.Decimal(18, 8)
  entryPrice Decimal?   @db.Decimal(18, 8)
  exitPrice  Decimal?   @db.Decimal(18, 8)
  pnl        Decimal?   @db.Decimal(18, 2)
  rMultiple  Decimal?   @db.Decimal(8, 2)

  openedAt DateTime    @default(now()) // best-known open time; defaults to creation
  closedAt DateTime?
  status   TradeStatus @default(TODO)

  // Per-field provenance so the UI can render confidence badges + "AI inferred"
  // hints. Shape: Record<TradeMarketField, { source: "ai" | "user", confidence?: number, voiceNoteId?: string, at: string }>.
  // Validated by Zod (TradeFieldSourcesSchema) on every write — not free-form JSON.
  fieldSources Json?

  // Cross-recording behavioural summary generated on demand via the
  // `/api/trades/[id]/summarize` endpoint. Validated by TradeSummaryV1 on
  // every read/write (see src/lib/ai/schema.ts). Carries the list of voice
  // note IDs it was generated from so the UI can flag staleness when new
  // recordings land.
  summary Json?

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  voiceNotes VoiceNote[]

  @@index([userId, openedAt])
  @@index([userId, status])
  @@index([projectId, openedAt])
}

enum Direction {
  LONG
  SHORT
}

// Lifecycle:
//   TODO      → newborn; AI hasn't finished, OR required fields are still null.
//   ANALYSED  → required fields all present (symbol + direction + entryPrice).
//               Auto-promoted from TODO on any write that satisfies the rule.
//   COMPLETED → user-locked; read-only; no more recordings accepted.
//               Only reachable via explicit user action; never auto-reverted.
enum TradeStatus {
  TODO
  ANALYSED
  COMPLETED
}

// =============================================================================
// VOICE NOTES — every recording belongs to exactly one Trade.
// `tradeId` is REQUIRED: there are no orphan voice notes in the trade-centric
// model. If no trade exists when an upload arrives, the upload route creates
// one before inserting the VoiceNote row.
// =============================================================================
model VoiceNote {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Denormalised mirror of trade.projectId for fast project-scoped queries.
  // MUST be kept in sync with trade.projectId on write.
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  tradeId String
  trade   Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  audioPath       String? // local file path in dev
  audioDurationMs Int?
  transcript      String  @db.Text // "" when AI never ran; payload then carries the error marker
  userNote        String? @db.Text // optional typed context for this recording

  screenshotPath  String?      // first image path; null when analysisMode = QUICK
  screenshotPaths Json?        // string[] of relative paths when multiple Deep images
  analysisMode    AnalysisMode @default(QUICK)

  // BehavioralPayload (see PRD §6). When AI failed/skipped, this is a stub
  // `{ error: "...", retryable: true }` so the row remains queryable.
  payload        Json
  payloadVersion String @default("v1")

  aiProvider String? // null when AI didn't run (budget cap / provider error)
  aiTier     String?

  context   NoteContext @default(POST_TRADE)
  createdAt DateTime    @default(now())

  aiUsageLogs AiUsageLog[]

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@index([tradeId])
}

enum NoteContext {
  PRE_TRADE
  DURING_TRADE
  POST_TRADE
  END_OF_DAY
  GENERAL
}

enum AnalysisMode {
  QUICK // voice transcript only
  DEEP // voice transcript + screenshot (vision)
}

// =============================================================================
// AI USAGE LOG — daily spend tracking
// =============================================================================
model AiUsageLog {
  id            String   @id @default(uuid())
  userId        String?
  // Attribution to the specific recording the spend was incurred for. Null
  // for non-note operations (e.g. project rule parsing, dev tooling) so the
  // usage log remains a general-purpose ledger.
  voiceNoteId   String?
  voiceNote     VoiceNote? @relation(fields: [voiceNoteId], references: [id], onDelete: SetNull)
  provider      String // "gemini" | "openai" | "anthropic" | "ollama" | "deepgram"
  model         String
  operation     String // "transcribe" | "analyze_quick" | "analyze_deep" | "parse_rules"
  inputTokens   Int?
  outputTokens  Int?
  imageTokens   Int? // populated only for vision (DEEP) calls
  estimatedCost Decimal  @db.Decimal(10, 6)
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([voiceNoteId])
}

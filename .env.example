# =============================================================================
# Trader's Mirror — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit .env*.
# =============================================================================

# --- Database --------------------------------------------------------------
# MySQL 8 (local). See PRD §3.1 for the one-time CREATE DATABASE / CREATE USER steps.
# Default port is 3306. Use a dedicated user in long-lived envs; `root` is fine for solo dev.
DATABASE_URL="mysql://traders_mirror_user:CHANGE_ME@localhost:3306/traders_mirror"

# --- Auth ------------------------------------------------------------------
# Reserved for future signed cookies. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET="generate-random-string-here"

# --- AI providers ----------------------------------------------------------
# Which tier the factory in src/lib/ai/index.ts picks: free | cheap | balanced | premium
AI_TIER="cheap"

# Daily safety cap (USD). The upload route refuses calls once today's spend hits this.
# Raised in PRD v2 to accommodate DEEP (vision) analysis cost.
DAILY_AI_BUDGET_USD="2.00"

OPENAI_API_KEY="sk-..."
GOOGLE_AI_API_KEY=""
ANTHROPIC_API_KEY=""

# --- Storage ---------------------------------------------------------------
# Local filesystem in dev. Swap for S3/Supabase later via storeAudio()/storeScreenshot().
AUDIO_STORAGE_DIR="./uploads/audio"
SCREENSHOT_STORAGE_DIR="./uploads/screenshots"

# --- Dev seed --------------------------------------------------------------
DEV_USER_EMAIL="founder@local.dev"
DEV_USER_PASSWORD="changeme123"
